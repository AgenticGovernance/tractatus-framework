# ============================================
# PUBLIC REPO: Additional Protections
# ============================================

# NEVER include internal documentation
CLAUDE.md
CLAUDE*.md
*Maintenance_Guide.md
SESSION-HANDOFF-*.md
NEXT_SESSION*.md
PHASE-*-PREPARATION*.md
*.backup
old*

# NEVER include session state
.claude/

# NEVER include secrets
*.key
*.pem
*.p12
*.pfx
secrets/
credentials/

# NEVER include database dumps
dump/
backups/
*.sql
*.sql.gz
*.dump

# NEVER include SSH keys
*.ssh/
id_rsa*
id_ed25519*

# NEVER include production configs with secrets
deployment-config.json
production.json

# NEVER include internal planning docs
docs/SESSION-*.md
docs/FRAMEWORK_FAILURE_*.md
docs/SECURITY_AUDIT_REPORT.md
docs/governance/MONTHLY-REVIEW-SCHEDULE.md
docs/governance/PRIVACY-PRESERVING-ANALYTICS-PLAN.md

# NEVER include temporary audit files
/tmp/*.md

# NEVER include screenshots
Screenshot*.png
*.screenshot.png
